page { 
  background:
    radial-gradient(circle at center, rgba(255,225,120,0.10) 0%, rgba(255,225,120,0) 22%),
    radial-gradient(circle at center, #2f8f5c 0%, #1a5b3a 48%, #103523 78%, #071912 100%);
  height: 100vh; width: 100vw; overflow: hidden;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, sans-serif;
}
.container {
  width: 100%; height: 100%;
  position: relative; background-size: cover; background-position: center;
}
.container::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  background:
    radial-gradient(circle at 50% 42%, rgba(255,244,185,0.12) 0%, rgba(255,244,185,0.05) 18%, rgba(255,244,185,0) 38%),
    repeating-linear-gradient(135deg, rgba(255,255,255,0.02) 0rpx, rgba(255,255,255,0.02) 3rpx, rgba(0,0,0,0.015) 3rpx, rgba(0,0,0,0.015) 6rpx),
    radial-gradient(circle at center, rgba(0,0,0,0) 45%, rgba(0,0,0,0.10) 70%, rgba(0,0,0,0.34) 100%);
  opacity: 0.92;
  z-index: 0;
}
.container::after {
  content: '';
  position: absolute;
  inset: 10rpx;
  border-radius: 28rpx;
  border: 1rpx solid rgba(255,220,120,0.12);
  box-shadow: inset 0 0 0 2rpx rgba(255,255,255,0.03), inset 0 0 36rpx rgba(255,240,170,0.04);
  pointer-events: none;
  z-index: 0;
}

.auth-page { width: 100%;
  height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center; position: relative; z-index: 1; padding: 0 24rpx; box-sizing: border-box;
}
.auth-title { font-size: 14rpx !important; margin-bottom: 14rpx !important; }
.auth-card { width: 100%; max-width: 520rpx; padding: 24rpx 22rpx 22rpx; border-radius: 24rpx;
  background: linear-gradient(180deg, rgba(24,22,17,0.94), rgba(12,11,8,0.90)); border: 1rpx solid rgba(255,221,145,0.26); box-shadow: 0 16rpx 36rpx rgba(0,0,0,0.32), inset 0 1rpx 0 rgba(255,255,255,0.08);
}
.auth-card-small { max-width: 312rpx; padding: 14rpx 13rpx 13rpx; border-radius: 14rpx; }
.auth-tabs { display: flex; gap: 12rpx; margin-bottom: 20rpx;
}
.auth-tabs-small { gap: 7rpx; margin-bottom: 12rpx; }
.auth-tab { flex: 1; text-align: center; padding: 12rpx 0; border-radius: 18rpx; color: #e7d7ae;
  background: rgba(255,255,255,0.06); font-size: 18rpx; font-weight: 700; }
.auth-tab.active { color: #5a3d06; background: linear-gradient(to bottom, #ffe59a, #f7b81f); box-shadow: 0 4rpx 10rpx rgba(247,184,31,0.22);
}
.auth-tabs-small .auth-tab { padding: 7rpx 0; border-radius: 11rpx; font-size: 11rpx; }
.user-setup { display: flex; flex-direction: column; align-items: center; margin-bottom: 10rpx;
}
.user-setup.compact { gap: 14rpx; }
.auth-compact { gap: 8rpx !important; margin-bottom: 6rpx; }
.avatar { width: 80rpx; height: 80rpx; border-radius: 50%;
  display: block; }
.auth-avatar-static { width: 48rpx; height: 48rpx; border-radius: 50%; display: block; border: 2rpx solid #ffd700;
  box-shadow: 0 0 0 2rpx rgba(255,255,255,0.08), 0 5rpx 12rpx rgba(0,0,0,0.35); margin-bottom: 4rpx; }
.auth-avatar-picker {
  width: 100%;
  max-width: 270rpx;
  white-space: nowrap;
}
.auth-avatar-list {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 4rpx 2rpx 6rpx;
}
.auth-avatar-item {
  width: 34rpx;
  height: 34rpx;
  border-radius: 10rpx;
  border: 1rpx solid rgba(255,255,255,0.35);
  box-shadow: 0 3rpx 8rpx rgba(0,0,0,0.24);
  opacity: 0.92;
}
.auth-avatar-item.active {
  border-color: #ffd54f;
  box-shadow: 0 0 0 2rpx rgba(255,213,79,0.24), 0 4rpx 10rpx rgba(0,0,0,0.28);
  opacity: 1;
}
.weui-input { border: 2rpx solid rgba(255,255,255,0.35); border-radius: 14rpx;
  padding: 0 14rpx; text-align: center; width: 100%; height: 44rpx; min-height: 44rpx; font-size: 18rpx; background: rgba(248,248,248,0.96);
  box-shadow: inset 0 2rpx 4rpx rgba(255,255,255,0.75), 0 6rpx 16rpx rgba(0,0,0,0.2); box-sizing: border-box; }
.auth-input-small { height: 26rpx; min-height: 26rpx; border-radius: 8rpx;
  padding: 0 8rpx; font-size: 11rpx; }
.auth-error { min-height: 28rpx; text-align: center; color: #ff9b8c; font-size: 16rpx; margin: 8rpx 0 10rpx;
}
.auth-card-small .auth-error { min-height: 16rpx; font-size: 10rpx; margin: 5rpx 0 6rpx; }
.auth-submit-btn { width: 100% !important; }
.auth-submit-btn-small { height: 28rpx;
  line-height: 28rpx; border-radius: 14rpx; font-size: 11rpx; }
.ghost-btn { width: 100% !important; height: 42rpx; line-height: 42rpx; border-radius: 21rpx;
  border: 1rpx solid rgba(255,225,150,0.26); color: #f7e6bc; font-size: 16rpx; background: rgba(255,255,255,0.06); margin-top: 14rpx; }
.ghost-btn::after { border: none;
}
.weui-input + .weui-input { margin-top: 0; }

.lobby { width: 100%; height: 100%; display: flex; flex-direction: column; align-items: center; justify-content: center;
  position: relative; z-index: 1; }
.title { font-size: 40rpx; color: #fff7d1; font-weight: 800;
  text-shadow: 0 2rpx 2rpx rgba(0,0,0,0.3), 0 0 12rpx rgba(255,215,90,0.28); margin-bottom: 20rpx; letter-spacing: 2rpx; }
.home-profile-card {
  width: 220rpx;
  height: 42rpx;
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
  margin-bottom: 18rpx;
  padding: 0 12rpx;
  border-radius: 21rpx;
  background: linear-gradient(135deg, rgba(34,28,18,0.94) 0%, rgba(18,16,10,0.88) 52%, rgba(72,50,16,0.92) 100%);
  border: 1rpx solid rgba(255,220,132,0.34);
  box-shadow: 0 4rpx 0 #6e4c14, 0 10rpx 16rpx rgba(0,0,0,0.22), inset 0 1rpx 0 rgba(255,255,255,0.12);
  box-sizing: border-box;
}
.home-profile-left { display: flex;
  flex-direction: row; align-items: center; justify-content: center; gap: 8rpx; width: 100%; min-width: 0; }
.home-profile-avatar { width: 28rpx; height: 28rpx; border-radius: 9rpx;
  border: 1rpx solid rgba(255,231,164,0.85); box-shadow: 0 0 0 2rpx rgba(255,213,79,0.10), 0 4rpx 8rpx rgba(0,0,0,0.20); flex-shrink: 0; }
.home-profile-meta { width: auto;
  min-width: 0; display: flex; flex-direction: row; align-items: center; justify-content: center; gap: 8rpx; }
.home-profile-name-row { display: flex; flex-direction: row; align-items: center;
  gap: 8rpx; width: auto; }
.home-profile-name { font-size: 16rpx; color: #fff8dc; font-weight: 800; max-width: 62rpx; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.home-profile-title { padding: 2rpx 8rpx; border-radius: 999rpx; font-size: 12rpx; color: #5a3d06; font-weight: 800; background: linear-gradient(to bottom, #ffe59a, #f7b81f); max-width: 74rpx;
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.home-profile-id { display: none; }
.home-profile-sign { display: none; }
.home-profile-right { display: none;
}
.home-profile-chip { display: none; }
.home-profile-enter { display: none; }
.auth-status-bar { margin-bottom: 16rpx; padding: 10rpx 16rpx; border-radius: 18rpx; background: rgba(255,240,184,0.10);
  border: 1rpx solid rgba(255,220,132,0.18); }
.auth-status-text { font-size: 14rpx; color: #ffe7ad; }
.btn-group { display: flex; flex-direction: column; gap: 20rpx;
}
.menu-btn {
  width: 130rpx !important; height: 42rpx; line-height: 42rpx;
  background: linear-gradient(to bottom, #ffe08a 0%, #ffc928 48%, #f1a903 100%);
  color: #5d4037; font-weight: bold; border-radius: 21rpx; font-size: 16rpx;
  border: 1rpx solid rgba(255,246,196,0.7);
  box-shadow: inset 0 2rpx 0 rgba(255,255,255,0.58), 0 4rpx 0 #b97700, 0 10rpx 16rpx rgba(0,0,0,0.28);
}
.menu-btn:active { transform: translateY(4rpx) scale(0.98);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.25), 0 2rpx 0 #b97700, 0 4rpx 8rpx rgba(0,0,0,0.2); }

.lobby-shop-entry {
  position: fixed;
  top: 22rpx;
  left: 20rpx;
  z-index: 9999;
  height: 40rpx;
  padding: 0 12rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: linear-gradient(135deg, rgba(255,238,186,0.98), rgba(255,205,97,0.98));
  border: 1rpx solid rgba(255,255,255,0.72);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.56), 0 4rpx 10rpx rgba(0,0,0,0.24);
}
.lobby-shop-entry:active { transform: scale(0.97); }
.lobby-shop-icon { font-size: 20rpx; }
.lobby-shop-text { font-size: 18rpx; color: #6c3b00; font-weight: 800; }

.room { width: 100%;
  height: 100%; position: relative; z-index: 1; }

.top-bar { position: fixed; top: 16rpx; left: 20rpx; display: flex; align-items: center; z-index: 9999;
}

.fix-room-id {
  font-size: 20rpx; color: #fff2b8; font-weight: bold;
  background: linear-gradient(to bottom, rgba(58,40,14,0.9), rgba(24,17,8,0.85));
  padding: 5rpx 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(255,220,120,0.45);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.16), 0 6rpx 14rpx rgba(0,0,0,0.28), 0 0 10rpx rgba(255,206,84,0.14);
  letter-spacing: 1rpx;
}

.counter-wrapper { position: fixed; top: 0; left: 0; z-index: 9999; display: flex; flex-direction: column; align-items: flex-start; gap: 4rpx;
}
.counter-toggle {
  background: linear-gradient(to bottom, rgba(29,35,19,0.92), rgba(12,17,10,0.86));
  color: #ffeb3b; font-size: 16rpx; font-weight: bold; padding: 6rpx 12rpx;
  border-radius: 0 0 12rpx 0; border: 1px solid rgba(255,230,154,0.34); pointer-events: auto;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.26);
}
.counter-toggle:active { opacity: 0.86;
}
.card-counter { display: flex; background: rgba(255, 251, 238, 0.96); border-radius: 0 0 14rpx 0; padding: 8rpx 12rpx;
  box-shadow: 0 8rpx 18rpx rgba(0,0,0,0.26); border: 1px solid rgba(230, 202, 145, 0.8); pointer-events: none; transform: scale(0.6); transform-origin: top left;
  opacity: 0.95; margin-top: 0; }
.cc-item { display: flex; flex-direction: column; align-items: center; padding: 0 8rpx; border-right: 1px solid rgba(120,96,55,0.12);
}
.cc-item:last-child { border-right: none; }
.cc-title { font-size: 16rpx; font-weight: 800; margin-bottom: 2rpx; color: #5b4724; }
.cc-count { font-size: 22rpx; color: #c62828;
  font-weight: 900; text-shadow: 0 1rpx 0 rgba(255,255,255,0.6); }
.cc-count.zero { color: #ccc; }

.chat-btn {
  position: fixed; bottom: 48rpx; width: 36rpx;
  height: 36rpx;
  border-radius: 50%; display: flex; justify-content: center; align-items: center;
  font-size: 18rpx; z-index: 9999; color: #fff;
  border: 1rpx solid rgba(255,255,255,0.35);
  background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.32), rgba(255,255,255,0.05) 35%, rgba(15,20,28,0.92) 100%);
  box-shadow: 0 6rpx 14rpx rgba(0,0,0,0.34), inset 0 1rpx 0 rgba(255,255,255,0.22);
  right: 16rpx;
}
.chat-btn:active { transform: scale(0.92); }
.chat-mask { position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: 10000;
}
.chat-menu { position: fixed; bottom: 94rpx; right: 12rpx; width: 260rpx; height: 220rpx; background: linear-gradient(to bottom, rgba(25,34,55,0.96), rgba(13,20,35,0.94)); border-radius: 16rpx;
  z-index: 10001; box-shadow: 0 10rpx 24rpx rgba(0,0,0,0.42); overflow-y: scroll; border: 1px solid rgba(255,222,140,0.16); }
.chat-item { padding: 14rpx 16rpx; font-size: 16rpx;
  color: #f6f0d8; font-weight: normal; border-bottom: 1px solid rgba(255,255,255,0.08); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; letter-spacing: 1rpx; }
.chat-item:active { background: rgba(255,255,255,0.12);
}

.chat-bubble, .my-chat-bubble {
  background: linear-gradient(to bottom, #fffdf4, #fff2c9);
  color: #5a421d; font-weight: bold;
  box-shadow: 0 6rpx 14rpx rgba(0,0,0,0.28);
  border: 2rpx solid #ffd54f;
}
.chat-bubble { position: absolute; padding: 6rpx 14rpx; border-radius: 16rpx; font-size: 16rpx; z-index: 200; white-space: nowrap;
}
.chat-bubble::after { content: ''; position: absolute; width: 0; height: 0; border: 6rpx solid transparent; }
.player-left .chat-bubble { left: 80rpx;
  top: -10rpx; }
.player-left .chat-bubble::after { left: -10rpx; top: 14rpx; border-right-color: #ffd54f; }
.player-right .chat-bubble { right: 80rpx; top: -10rpx;
}
.player-right .chat-bubble::after { right: -10rpx; top: 14rpx; border-left-color: #ffd54f; }
.player-top .chat-bubble { top: 60rpx; left: 50%; transform: translateX(-50%);
}
.player-top .chat-bubble::after { top: -10rpx; left: 50%; transform: translateX(-50%); border-bottom-color: #ffd54f; }
.my-chat-bubble { position: fixed; bottom: 150rpx; left: 50%;
  transform: translateX(-50%); padding: 6rpx 14rpx; border-radius: 16rpx; font-size: 16rpx; z-index: 200; }

.desk { width: 100%; height: 100%; position: absolute;
  top: 0; left: 0; pointer-events: none; z-index: 50; }
.player-side {
  position: absolute; width: 70rpx; display: flex; flex-direction: column;
  align-items: center; pointer-events: auto;
  background: linear-gradient(to bottom, rgba(13,27,20,0.52), rgba(5,14,11,0.44));
  padding: 8rpx 6rpx; border-radius: 14rpx;
  border: 1rpx solid rgba(255,219,128,0.18);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.08), 0 8rpx 18rpx rgba(0,0,0,0.22);
  backdrop-filter: blur(4rpx);
  z-index: 120;
}
.player-left { left: 12rpx; top: 36%;
}
.player-right { right: 12rpx; top: 36%; }
.player-top { top: 6rpx; left: 50%; transform: translateX(-50%); flex-direction: row; width: auto;
  padding: 6rpx 14rpx; }

.avatar-box {
  width: 40rpx; height: 40rpx; border-radius: 10rpx;
  background: linear-gradient(to bottom, rgba(255,255,255,0.18), rgba(255,255,255,0.08));
  display: flex;
  justify-content: center; align-items: center; position: relative; margin-bottom: 4rpx;
  border: 1rpx solid rgba(255,233,170,0.34);
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.24), 0 0 10rpx rgba(255,219,100,0.10);
}
.player-top .avatar-box { margin-bottom: 0; margin-right: 8rpx;
}
.avatar-emoji { font-size: 26rpx; }
.avatar-img { width: 100%; height: 100%; border-radius: 10rpx; display: block; }
.avatar-img.offline { filter: grayscale(100%); opacity: 0.65;
}
.friend-tag { position: absolute; top: -10rpx; left: -10rpx; background: linear-gradient(to bottom, #ff8a65, #e64a19); color: #fff; font-size: 16rpx; font-weight: bold;
  padding: 2rpx 6rpx; border-radius: 8rpx; border: 2rpx solid #fff4dc; z-index: 10; box-shadow: 0 2rpx 4rpx rgba(0,0,0,0.4);
}
.disconnect-tag {
  position: absolute;
  right: -8rpx;
  top: -8rpx;
  z-index: 12;
  padding: 1rpx 5rpx;
  border-radius: 8rpx;
  font-size: 10rpx;
  color: #fff;
  background: linear-gradient(to bottom, #9e9e9e, #616161);
  border: 1rpx solid rgba(255,255,255,0.5);
}
.name-text { font-size: 16rpx; color: #fff7da; width: 100%; text-align: center;
  white-space: nowrap; overflow: hidden; text-shadow: 0 2rpx 6rpx rgba(0,0,0,0.45); }
.player-equip-text {
  margin-top: 2rpx;
  max-width: 96rpx;
  font-size: 10rpx;
  line-height: 1.2;
  color: #ffe9b0;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}
.player-equip-text.top {
  max-width: 180rpx;
  text-align: left;
}
.avatar-box.frame-rare {
  border-color: #5bc0ff;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.24), 0 0 12rpx rgba(91,192,255,0.45);
}
.avatar-box.frame-epic {
  border-color: #d28dff;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.24), 0 0 14rpx rgba(210,141,255,0.55);
}
.avatar-box.frame-legend {
  border-color: #ffd54f;
  box-shadow: inset 0 1rpx 0 rgba(255,255,255,0.24), 0 0 16rpx rgba(255,213,79,0.65);
}
.avatar-box.effect-rare::after,
.avatar-box.effect-epic::after,
.avatar-box.effect-legend::after {
  content: '';
  position: absolute;
  inset: -4rpx;
  border-radius: 12rpx;
  pointer-events: none;
}
.avatar-box.effect-rare::after {
  border: 1rpx solid rgba(96,215,255,0.55);
}
.avatar-box.effect-epic::after {
  border: 1rpx solid rgba(220,150,255,0.62);
}
.avatar-box.effect-legend::after {
  border: 1rpx solid rgba(255,220,120,0.72);
  box-shadow: 0 0 10rpx rgba(255,220,120,0.55);
}
.card-remain { font-size: 14rpx; color: #fff;
  background: linear-gradient(to bottom, #ef5350, #c62828); padding: 2rpx 8rpx; border-radius: 10rpx; margin-top: 4rpx; box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.2);
}

.center-area { position: absolute; top: 30%; left: 50%; transform: translate(-50%, -50%); width: 100%; display: flex; flex-direction: column; align-items: center;
  z-index: 200; pointer-events: none; }
.msg-tip { font-size: 20rpx; color: #fff7d1; background: linear-gradient(to bottom, rgba(28,31,18,0.82), rgba(11,14,8,0.74)); padding: 6rpx 18rpx; border-radius: 18rpx;
  border: 1rpx solid rgba(255,219,120,0.22); box-shadow: 0 6rpx 14rpx rgba(0,0,0,0.24); }

.played-cards-row { position: absolute; display: flex; align-items: center; justify-content: center;
  z-index: 60; pointer-events: none; min-height: 60rpx; max-width: 320rpx; }
.played-cards-row.pos-bottom { bottom: 104rpx; left: 50%; transform: translateX(-50%); }
.played-cards-row.pos-left { left: 102rpx;
  top: 56%; transform: translateY(-50%); justify-content: flex-start; }
.played-cards-row.pos-right { right: 92rpx; top: 56%; transform: translateY(-50%); justify-content: flex-end; }
.played-cards-row.pos-top { top: 65rpx;
  left: 50%; transform: translateX(-50%); }

.small-card {
  width: 44rpx; height: 60rpx; background: linear-gradient(to bottom, #fffefb 0%, #f8f0dd 100%);
  border-radius: 8rpx;
  border: 1px solid #b8a27a; 
  margin-left: -18rpx; /* 控制重叠收拢间距 */
  position: relative;
  box-shadow: -2rpx 0 5rpx rgba(0,0,0,0.25), inset 0 1rpx 0 rgba(255,255,255,0.72);
  overflow: hidden;
}
.small-card:first-child {
  margin-left: 0;
  /* 第一张牌不缩进，防止整排位置跑偏 */
}
.small-card::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(135deg, rgba(255,255,255,0.45), rgba(255,255,255,0) 40%);
  pointer-events: none;
}
.small-card .card-num { position: absolute; top: 1rpx; left: 2rpx; font-size: 19rpx; font-weight: bold; line-height: 1; white-space: nowrap; letter-spacing: -2rpx;
  z-index: 2; }

/* 👇 核心修复：把花色移到了左下角，并且稍微放大了一点保证清晰可见 */
.small-card .card-suit { position: absolute; bottom: 4rpx; left: 4rpx; font-size: 22rpx; line-height: 1; z-index: 2;
}

.action-tag {
  position: absolute; background: linear-gradient(to bottom, rgba(61,38,15,0.96), rgba(24,16,8,0.92));
  color: #ffe9a6; font-size: 18rpx; padding: 5rpx 12rpx; border-radius: 12rpx;
  white-space: nowrap; font-weight: bold; z-index: 100;
  border: 1px solid rgba(255, 225, 138, 0.32);
  box-shadow: 0 6rpx 14rpx rgba(0,0,0,0.32), 0 0 10rpx rgba(255,199,89,0.10);
}
.pass-toast {
  position: absolute;
  left: 50%;
  top: 46%;
  transform: translate(-50%, -50%);
  z-index: 130;
  padding: 6rpx 14rpx;
  border-radius: 14rpx;
  background: linear-gradient(to bottom, rgba(61,38,15,0.98), rgba(24,16,8,0.94));
  color: #ffe9a6;
  font-size: 15rpx;
  font-weight: bold;
  white-space: nowrap;
  border: 1rpx solid rgba(255, 225, 138, 0.36);
  box-shadow: 0 6rpx 12rpx rgba(0,0,0,0.34), 0 0 10rpx rgba(255,199,89,0.10);
