.shop-item-name {
  font-size: 12rpx;
  color: #fff4d1;
  font-weight: 800;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 82rpx;
}
.shop-item-desc {
  margin-top: 1rpx;
  font-size: 10rpx;
  color: rgba(255,240,205,0.92);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  max-width: 82rpx;
}
.shop-item-action {
  display: flex;
  align-items: center;
  gap: 5rpx;
  flex-shrink: 0;
}
.shop-item-price {
  font-size: 11rpx;
  color: #ffd86b;
  font-weight: 700;
}
.shop-item-btns {
  display: flex;
  gap: 4rpx;
}
.shop-buy-btn {
  width: 52rpx !important;
  height: 26rpx;
  line-height: 26rpx;
  border-radius: 13rpx;
  padding: 0;
  font-size: 11rpx;
  font-weight: 800;
  color: #5f3a00;
  background: #ffd257;
  border: 1rpx solid rgba(255,255,255,0.5);
  box-shadow: none;
}
.shop-buy-btn.owned {
  color: rgba(255,255,255,0.92);
  background: linear-gradient(to bottom, #607d8b, #455a64);
  border-color: rgba(255,255,255,0.3);
}
.shop-equip-btn {
  width: 52rpx !important;
  height: 26rpx;
  line-height: 26rpx;
  border-radius: 13rpx;
  padding: 0;
  font-size: 11rpx;
  font-weight: 800;
  color: #f0f6ff;
  background: #3b5670;
  border: 1rpx solid rgba(255,255,255,0.26);
}
.shop-equip-btn.equipped {
  color: #fff6d6;
  background: #4f7a3d;
}
.shop-buy-btn::after,
.shop-equip-btn::after {
  border: none;
}

/* 👇 新增：打出的牌右下角数字样式 */
.small-card .card-num-bottom-right {
  position: absolute;
  bottom: 4rpx;     /* 距离底部的高度 */
  right: 4rpx;      /* 距离右侧的宽度 */
  font-size: 19rpx; /* 和左上角数字大小保持一致 */
  font-weight: bold;
  line-height: 1;
  letter-spacing: -2rpx;
  z-index: 2;
}

/* 👇 新增：聊天按钮上方的局数进度提示 */
.round-indicator {
  position: fixed;
  bottom: 30rpx; /* 卡在 chat-btn 48rpx 的正上方 */
  right: 50rpx;  /* 宽度对齐聊天按钮 */
  padding: 4rpx 10rpx;
  border-radius: 12rpx;
  background: linear-gradient(to bottom, rgba(61,38,15,0.92), rgba(24,16,8,0.88));
  border: 1rpx solid rgba(255, 225, 138, 0.32);
  color: #ffe9a6;
  font-size: 13rpx;
  font-weight: bold;
  z-index: 9999;
  text-align: center;
  box-shadow: 0 4rpx 10rpx rgba(0,0,0,0.3);
  pointer-events: none; /* 防止挡住点击 */
}